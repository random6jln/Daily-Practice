target = input("Please enter a word to reverse! ")
targetlist = input("Please enter a list to reverse! ")
result = ""

for x in target:  #when you're manipulating a string it reads it like h,e,l,l,o. It shows you each piece by piece. 
    result = x + result #so here you're just adding the characters together with the blank variable, making one in reverse


resultlist = []

for y in targetlist.split(","):  #ok so split splits up a a string into list of substrings based on a delimiter, in this case it accounts for adding comas to the string 
    resultlist = [int(y)] + resultlist # so a line like resultlist.append(int(y)) changes EACH piece (hence the loop) into an int and adds it into the list. 
                                       #The line does that and reverses it
    
print(result)
print(resultlist)

